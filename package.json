{
  "name": "complete_business_analysis_tool",
  "version": "1.0.0",
  "description": "Complete Business Analysis Tool for understanding strength and weakness of business and creating a plan for success.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "sass": "sass --load-path=node_modules complete_business_analysis_tool/static/sass/project.sass complete_business_analysis_tool/static/css/project.min.css --style=compressed --watch",
    "browsersync": "browser-sync start --proxy 'localhost:8000' --files 'complete_business_analysis_tool/static/css/*.css, complete_business_analysis_tool/templates/**/*.html'",
    "django": "python manage.py runserver",
    "dev": "npm-run-all --parallel django sass browsersync",
    "build": "npm run sass:build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gravic07/complete-business-analysis.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/gravic07/complete-business-analysis/issues"
  },
  "homepage": "https://github.com/gravic07/complete-business-analysis#readme",
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "bulma": "^1.0.4",
    "npm-run-all": "^4.1.5",
    "sass": "^1.99.0"
  }
}
